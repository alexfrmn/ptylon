# Required
AUTH_PASSWORD=change-me
JWT_SECRET=replace-with-a-long-random-secret
# Optional local control-plane token. Defaults to JWT_SECRET when unset.
# WEB_CONSOLE_ADMIN_TOKEN=replace-with-a-long-random-secret
# Set true only for local HTTP testing. Production HTTPS should leave this unset/false.
# ALLOW_INSECURE_COOKIE=false

# Ports
PORT=8790
WS_PORT=8791
# Required when a remote reverse proxy forwards /ws directly to this VM.
WS_HOST=0.0.0.0
NEXT_PUBLIC_WS_PORT=8791
PTY_DAEMON_HOST=127.0.0.1
PTY_DAEMON_PORT=8792
PTY_DAEMON_URL=ws://127.0.0.1:8792
PTY_IDLE_TIMEOUT_HOURS=168

# Local paths
WORKSPACE_ROOT=/workspace
FILE_ACCESS_ROOT=/workspace
# Unsafe compatibility escape hatch. Leave false for self-hosted deployments.
ALLOW_FULL_FILESYSTEM=false
ALLOWED_CWD_ROOT=/workspace
UPLOAD_DIR=/workspace/uploads
NEXT_PUBLIC_WORKSPACE_ROOT=/workspace
NEXT_PUBLIC_UPLOAD_DIR=/workspace/uploads

# UI label shown in the footer/login page
NEXT_PUBLIC_APP_LABEL=Ptylon

# Optional: admin browser automation
# CHROME=/usr/bin/google-chrome
# WEB_CONSOLE_BROWSER_SESSION_TTL_MS=600000

# Optional: voice transcription
# GROQ_API_KEY=
