{
  "name": "ptylon",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "bin": {
    "webc": "./bin/webc.mjs"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build && ln -sfn ../../static .next/standalone/.next/static && ln -sfn ../../public .next/standalone/public",
    "start": "next start",
    "start:ws": "node --env-file=.env server/ws-server.mjs",
    "start:pty": "node --env-file=.env server/pty-daemon.mjs",
    "test:pty-gateway": "node scripts/smoke-pty-gateway.mjs",
    "test:pty-network-policy": "node scripts/test-pty-network-policy.mjs",
    "test:browser-regression": "node scripts/browser-regression.mjs",
    "test:playwright-smoke": "node scripts/playwright-smoke.mjs",
    "capture:showcase": "node scripts/capture-showcase.mjs",
    "webc": "node bin/webc.mjs",
    "lint": "eslint"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "jsonwebtoken": "^9.0.3",
    "next": "16.2.6",
    "node-pty": "^1.1.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "uuid": "^13.0.0",
    "ws": "^8.21.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "playwright": "1.57.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
